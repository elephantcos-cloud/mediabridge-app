<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp" android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="10dp" app:cardElevation="2dp">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="14dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical">
      <TextView android:id="@+id/tv_queue_name"
          android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
          android:textColor="@color/text_primary" android:textSize="14sp"
          android:fontFamily="sans-serif-medium" android:ellipsize="end" android:singleLine="true"/>
      <TextView android:id="@+id/tv_queue_pct"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:textColor="@color/accent_purple" android:textSize="14sp"
          android:fontFamily="sans-serif-medium" android:layout_marginStart="8dp"/>
    </LinearLayout>
    <TextView android:id="@+id/tv_queue_format"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="2dp" android:textColor="@color/text_secondary" android:textSize="11sp"/>
    <ProgressBar android:id="@+id/queue_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent" android:layout_height="6dp"
        android:layout_marginTop="8dp"
        android:progressTint="@color/accent_purple"
        android:progressBackgroundTint="@color/bg_dark"/>
    <TextView android:id="@+id/tv_queue_status"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="4dp" android:textSize="12sp"/>
  </LinearLayout>
</androidx.cardview.widget.CardView>
