<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_pick_file"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Pick Files to Convert" android:textSize="15sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/accent_purple" app:cornerRadius="12dp"
            app:icon="@drawable/ic_convert" app:iconGravity="start"/>
        <TextView android:id="@+id/tv_status"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp" android:text="Pick files to convert."
            android:textColor="@color/text_secondary" android:textSize="13sp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_done"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:layout_marginTop="8dp" android:text="Clear Completed"
            android:textColor="@color/text_secondary" android:textSize="12sp"
            app:backgroundTint="@color/card_bg"
            app:strokeColor="@color/text_secondary" app:strokeWidth="1dp"
            app:cornerRadius="18dp"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="16dp" android:layout_marginTop="10dp"
        android:text="QUEUE" android:textColor="@color/text_secondary"
        android:textSize="11sp" android:letterSpacing="0.1"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/queue_recycler"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:layout_marginTop="6dp"
        android:paddingBottom="80dp" android:clipToPadding="false"/>
    <View android:id="@+id/card_file_info" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tv_file_name" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tv_file_info" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/spinner_format_card" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <Spinner android:id="@+id/spinner_format" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <View android:id="@+id/progress_group" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <ProgressBar android:id="@+id/progress_bar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <TextView android:id="@+id/tv_elapsed" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
    <com.google.android.material.button.MaterialButton android:id="@+id/btn_convert"
        android:layout_width="0dp" android:layout_height="0dp" android:text="x"
        android:visibility="gone" app:backgroundTint="@color/card_bg"/>
    <com.google.android.material.button.MaterialButton android:id="@+id/btn_cancel"
        android:layout_width="0dp" android:layout_height="0dp" android:text="x"
        android:visibility="gone" app:backgroundTint="@color/card_bg"/>
</LinearLayout>
