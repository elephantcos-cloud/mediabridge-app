<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:fillViewport="true">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="vertical" android:padding="16dp">

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 1 — SELECT MEDIA FILE"
            android:textColor="@color/text_secondary" android:textSize="11sp" android:letterSpacing="0.1"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_pick_file"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginTop="10dp" android:text="Pick Video / Audio / Image"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/accent_purple" app:cornerRadius="10dp"
            app:icon="@drawable/ic_convert" app:iconGravity="start"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:id="@+id/card_file_info"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="SELECTED FILE" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:letterSpacing="0.1"/>
        <TextView android:id="@+id/tv_file_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textColor="@color/text_primary"
            android:textSize="15sp" android:fontFamily="sans-serif-medium"
            android:ellipsize="middle" android:singleLine="true"/>
        <TextView android:id="@+id/tv_file_info"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="4dp" android:textColor="@color/accent_teal" android:textSize="13sp"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 2 — SELECT OUTPUT FORMAT"
            android:textColor="@color/text_secondary" android:textSize="11sp" android:letterSpacing="0.1"/>
        <Spinner android:id="@+id/spinner_format"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginTop="10dp" android:background="@drawable/bg_spinner"
            android:paddingStart="12dp" android:paddingEnd="12dp"
            android:popupBackground="@color/card_bg"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content" android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_convert"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="Convert for Button Phone" android:textSize="16sp"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/accent_teal" app:cornerRadius="10dp"/>
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_cancel"
            android:layout_width="match_parent" android:layout_height="44dp"
            android:layout_marginTop="8dp" android:text="Cancel"
            android:textColor="@color/text_secondary" android:visibility="gone"
            app:backgroundTint="@color/card_bg"
            app:strokeColor="@color/text_secondary" app:strokeWidth="1dp" app:cornerRadius="10dp"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView android:id="@+id/progress_group"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" android:visibility="gone"
        app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="12dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
          android:orientation="vertical" android:padding="16dp">
        <ProgressBar android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="8dp"
            android:progressTint="@color/accent_purple"
            android:progressBackgroundTint="@color/bg_dark"/>
        <TextView android:id="@+id/tv_elapsed"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp" android:textColor="@color/accent_teal" android:textSize="13sp"/>
      </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView android:id="@+id/tv_status"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:padding="8dp" android:textColor="@color/text_secondary"
        android:textSize="13sp" android:lineSpacingExtra="4dp"
        android:text="Pick a file to get started."/>
  </LinearLayout>
</ScrollView>
