<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp" android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/card_bg" app:cardCornerRadius="10dp" app:cardElevation="2dp">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
      android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
    <ImageView android:id="@+id/thumbnail"
        android:layout_width="60dp" android:layout_height="60dp"
        android:scaleType="centerCrop" android:background="@color/bg_dark"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
      <TextView android:id="@+id/title"
          android:layout_width="match_parent" android:layout_height="wrap_content"
          android:textColor="@color/text_primary" android:textSize="14sp"
          android:fontFamily="sans-serif-medium" android:ellipsize="end" android:singleLine="true"/>
      <TextView android:id="@+id/subtitle"
          android:layout_width="wrap_content" android:layout_height="wrap_content"
          android:layout_marginTop="3dp" android:textColor="@color/text_secondary" android:textSize="12sp"/>
    </LinearLayout>
    <ImageView android:id="@+id/type_icon"
        android:layout_width="22dp" android:layout_height="22dp"
        android:layout_marginStart="8dp" android:alpha="0.5"/>
  </LinearLayout>
</androidx.cardview.widget.CardView>
